<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="550.0" prefWidth="450.0" stylesheets="@styles.css" styleClass="pane-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinal.ViewController.LoginViewController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
            <children>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="🎟️" style="-fx-font-size: 50px;" />
                        <Label text="Nexus Tickets" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #58a6ff;" />
                        <Label text="Inicia sesión para continuar" style="-fx-text-fill: #8b949e;" />
                    </children>
                </VBox>

                <Separator prefWidth="200.0" style="-fx-padding: 10 0;" />

                <VBox spacing="15.0" prefWidth="370.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Cédula o Correo Electrónico" style="-fx-text-fill: #c9d1d9; -fx-font-weight: bold;" />
                            <TextField fx:id="txtUsuario" promptText="Ingresa tu usuario..." prefHeight="38.0" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Contraseña" style="-fx-text-fill: #c9d1d9; -fx-font-weight: bold;" />
                            <PasswordField fx:id="txtContrasena" promptText="••••••••" prefHeight="38.0" />
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" alignment="CENTER" prefWidth="370.0" style="-fx-padding: 15 0 0 0;">
                    <children>
                        <Button mnemonicParsing="false" onAction="#login" text="🔑 Entrar" prefHeight="45.0" prefWidth="370.0" style="-fx-background-color: #1f6feb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="¿No tienes cuenta?" style="-fx-text-fill: #8b949e;" />
                                <Button mnemonicParsing="false" onAction="#irAPantallaRegistro" text="Regístrate aquí" style="-fx-background-color: transparent; -fx-text-fill: #58a6ff; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>