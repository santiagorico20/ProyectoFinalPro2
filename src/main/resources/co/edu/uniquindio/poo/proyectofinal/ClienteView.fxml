<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1050.0" style="-fx-background-color: #0d1117;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinal.ViewController.ClienteViewController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <VBox spacing="15.0" HBox.hgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Label text="🎟️ Compra de Entradas" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #58a6ff;" />
                        </children>
                    </HBox>

                    <HBox spacing="15.0">
                        <VBox spacing="5.0"><Label text="1. Elige un Evento:" style="-fx-text-fill: #c9d1d9;"/><ComboBox fx:id="comboEventos" prefWidth="200.0"/></VBox>
                        <VBox spacing="5.0"><Label text="2. Elige la Zona:" style="-fx-text-fill: #c9d1d9;"/><ComboBox fx:id="comboZonas" prefWidth="200.0"/></VBox>
                    </HBox>

                    <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                        <content>
                            <GridPane fx:id="gridAsientosCliente" alignment="CENTER" style="-fx-padding: 20;" />
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox fx:id="panelPago" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #161b22; -fx-padding: 20; -fx-border-color: #30363d; -fx-border-radius: 8;" visible="false">
                    <Label text="🛒 Tu Carrito" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #c9d1d9;" />

                    <ListView fx:id="listaCarrito" prefHeight="200.0" style="-fx-background-color: #0d1117;" />

                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Total a pagar:" style="-fx-font-size: 16px; -fx-text-fill: #8b949e;" />
                        <Label fx:id="lblTotalPago" text="\$ 0.0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2ea043;" />
                    </HBox>

                    <Separator style="-fx-opacity: 0.2;"/>

                    <VBox spacing="8.0">
                        <Label text="💳 Método de Pago:" style="-fx-text-fill: #c9d1d9;" />
                        <ComboBox fx:id="comboMetodoPago" prefWidth="300.0" promptText="Seleccionar..." />
                    </VBox>

                    <Button onAction="#procesarPago" text="Confirmar y Pagar" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #2ea043; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" VBox.vgrow="ALWAYS"/>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>