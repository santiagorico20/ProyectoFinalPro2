<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="1050.0" stylesheets="@styles.css" styleClass="pane-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinal.ViewController.AdminViewController">
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25 15 25 15; -fx-border-color: #e8e8e8; -fx-border-width: 0 1 0 0;">
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-padding: 0 0 20 0;">
                            <children>
                                <Label text="🛡️ Nexus Admin" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #096dd9;" />
                                <Label text="Panel de Control Global" style="-fx-font-size: 11px; -fx-text-fill: #8c8c8c;" />
                            </children>
                        </VBox>
                        <Separator style="-fx-background-color: #e8e8e8; -fx-opacity: 0.6;" />
                        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button mnemonicParsing="false" onAction="#mostrarPanelEventos" text="📅 Gestionar Eventos" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                                <Button mnemonicParsing="false" onAction="#mostrarPanelRecintos" text="🏛️ Configurar Recintos" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                                <Button mnemonicParsing="false" onAction="#mostrarPanelAsientos" text="💺 Mapa de Asientos" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                                <Button mnemonicParsing="false" onAction="#mostrarPanelUsuarios" text="👥 Lista de Usuarios" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                                <Button mnemonicParsing="false" onAction="#mostrarPanelMetricas" text="📊 Métricas de Ventas" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                                <Button mnemonicParsing="false" onAction="#abrirGestionIncidencias" text="🛠️ Panel de Incidencias" prefHeight="40.0" prefWidth="220.0" styleClass="button-sidebar" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" />
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#cerrarSesion" text="🚪 Cerrar Sesión" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #ff4d4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" />
                    </children>
                </VBox>

                <ScrollPane fitToHeight="true" fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f7fa; -fx-background: #f5f7fa;">
                    <content>
                        <StackPane fx:id="stackContenido" style="-fx-padding: 30; -fx-background-color: #f5f7fa;">
                            <children>

                                <VBox fx:id="panelBienvenida" alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Label text="👋" style="-fx-font-size: 60px;" />
                                        <Label text="¡Bienvenido al Panel Administrador!" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #262626;" />
                                    </children>
                                </VBox>

                                <VBox fx:id="panelEventos" spacing="20.0" visible="false">
                                    <children>
                                        <Label text="Gestión Integral de Eventos" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #096dd9;" />
                                        <HBox spacing="15.0" alignment="BOTTOM_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #e8e8e8; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Nombre Evento" style="-fx-text-fill: #434343;"/><TextField fx:id="txtNombreEvento"/></VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Descripción" style="-fx-text-fill: #434343;"/><TextField fx:id="txtDescEvento"/></VBox>
                                                <VBox spacing="5.0"><Label text="Fecha" style="-fx-text-fill: #434343;"/><DatePicker fx:id="dpFechaEvento" prefWidth="130.0"/></VBox>
                                                <VBox spacing="5.0"><Label text="Recinto" style="-fx-text-fill: #434343;"/><ComboBox fx:id="comboRecintoEvento" prefWidth="130.0"/></VBox>
                                                <Button onAction="#crearEvento" text="➕ Crear" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #52c41a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tablaEventos" VBox.vgrow="ALWAYS" prefHeight="300.0">
                                            <columns>
                                                <TableColumn fx:id="colEventoId" prefWidth="110.0" text="ID Evento" />
                                                <TableColumn fx:id="colEventoNombre" prefWidth="180.0" text="Nombre" />
                                                <TableColumn fx:id="colEventoCiudad" prefWidth="120.0" text="Ciudad" />
                                                <TableColumn fx:id="colEventoFecha" prefWidth="170.0" text="Fecha" />
                                                <TableColumn fx:id="colEventoEstado" prefWidth="130.0" text="Estado" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="15.0" alignment="CENTER_RIGHT">
                                            <children>
                                                <Button onAction="#eliminarEvento" text="🗑️ Eliminar" prefHeight="35.0" style="-fx-background-color: #8c8c8c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                                <Button onAction="#cancelarEventoSeleccionado" text="🚫 Cancelar" prefHeight="35.0" style="-fx-background-color: #ff4d4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                                <Button onAction="#publicarEventoSeleccionado" text="🚀 Publicar" prefHeight="35.0" style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="panelRecintos" spacing="20.0" visible="false">
                                    <children>
                                        <Label text="Paso 1: Crear el Complejo Físico" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #096dd9;" />
                                        <HBox spacing="15.0" alignment="BOTTOM_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #e8e8e8; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Nombre del Recinto" style="-fx-text-fill: #434343;"/><TextField fx:id="txtNombreRecinto" promptText="Ej: Movistar Arena" /></VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Ciudad" style="-fx-text-fill: #434343;"/><TextField fx:id="txtCiudadRecinto" promptText="Ej: Bogotá" /></VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Dirección" style="-fx-text-fill: #434343;"/><TextField fx:id="txtDireccionRecinto" promptText="Ej: Carrera 30" /></VBox>
                                                <Button onAction="#crearRecinto" text="🏗️ Guardar Edificio" prefHeight="35.0" style="-fx-background-color: #52c41a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
                                            </children>
                                        </HBox>

                                        <Label text="Paso 2: Generar y Asignar Zonas de Precios" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #fa8c16; -fx-padding: 10 0 0 0;" />
                                        <HBox spacing="15.0" alignment="BOTTOM_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #e8e8e8; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                                            <children>
                                                <VBox spacing="5.0"><Label text="Elegir Recinto" style="-fx-text-fill: #434343;"/><ComboBox fx:id="comboRecintoParaZona" prefWidth="140.0" /></VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS"><Label text="Nombre de la Zona" style="-fx-text-fill: #434343;"/><TextField fx:id="txtNombreZona" promptText="Ej: VIP Frontal" /></VBox>
                                                <VBox spacing="5.0"><Label text="Capacidad" style="-fx-text-fill: #434343;"/><TextField fx:id="txtCapacidadZona" prefWidth="90.0" promptText="Ej: 100" /></VBox>
                                                <VBox spacing="5.0"><Label text="Precio $" style="-fx-text-fill: #434343;"/><TextField fx:id="txtPrecioZona" prefWidth="110.0" promptText="Ej: 50000" /></VBox>
                                                <VBox alignment="CENTER" spacing="5.0"><Label text="Numerada" style="-fx-text-fill: #434343;"/><CheckBox fx:id="chkEsNumerada" selected="true" /></VBox>
                                                <Button onAction="#crearZonaParaRecinto" text="💺 Añadir Zona" prefHeight="35.0" style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;"/>
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tablaRecintos" VBox.vgrow="ALWAYS" prefHeight="200.0">
                                            <columns>
                                                <TableColumn fx:id="colRecintoId" prefWidth="120.0" text="ID Recinto" />
                                                <TableColumn fx:id="colRecintoNombre" prefWidth="220.0" text="Complejo" />
                                                <TableColumn fx:id="colRecintoCiudad" prefWidth="150.0" text="Ciudad" />
                                                <TableColumn fx:id="colRecintoDireccion" prefWidth="200.0" text="Dirección" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="15.0" alignment="CENTER_RIGHT">
                                            <children>
                                                <Button onAction="#eliminarZona" text="🗑️ Eliminar Zona..." prefHeight="35.0" style="-fx-background-color: #fa8c16; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                                <Button onAction="#eliminarRecinto" text="❌ Eliminar Recinto" prefHeight="35.0" style="-fx-background-color: #ff4d4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="panelAsientos" spacing="20.0" visible="false">
                                    <children>
                                        <Label text="Renderizado 2D del Mapa de Asientos" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #096dd9;" />
                                        <HBox spacing="20.0" alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #e8e8e8; -fx-border-radius: 6;">
                                            <children>
                                                <VBox spacing="5.0"><Label text="Recinto:" style="-fx-text-fill: #434343;"/><ComboBox fx:id="comboRecintoAsientos" prefWidth="180.0" /></VBox>
                                                <VBox spacing="5.0"><Label text="Zona Numerada:" style="-fx-text-fill: #434343;"/><ComboBox fx:id="comboZonaAsientos" prefWidth="180.0" /></VBox>
                                                <Button onAction="#cargarMapaAsientos" text="🔍 Dibujar Sillas" prefHeight="35.0" style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                            </children>
                                        </HBox>

                                        <HBox spacing="20.0" alignment="CENTER" style="-fx-padding: 5 0;">
                                            <children>
                                                <HBox alignment="CENTER" spacing="5.0"><Region style="-fx-background-color: #52c41a; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/> <Label text="Libre" style="-fx-text-fill: #434343;" /></HBox>
                                                <HBox alignment="CENTER" spacing="5.0"><Region style="-fx-background-color: #fa8c16; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/> <Label text="Reservado" style="-fx-text-fill: #434343;" /></HBox>
                                                <HBox alignment="CENTER" spacing="5.0"><Region style="-fx-background-color: #ff4d4f; -fx-pref-width: 15; -fx-pref-height: 15; -fx-background-radius: 3;"/> <Label text="Ocupado" style="-fx-text-fill: #434343;" /></HBox>
                                            </children>
                                        </HBox>

                                        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #ffffff; -fx-border-color: #e8e8e8; -fx-border-radius: 6;" VBox.vgrow="ALWAYS">
                                            <content>
                                                <GridPane fx:id="gridAsientos" alignment="CENTER" style="-fx-padding: 30; -fx-background-color: #ffffff;" />
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>

                                <VBox fx:id="panelUsuarios" spacing="20.0" visible="false">
                                    <children>
                                        <Label text="Usuarios Registrados" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #096dd9;" />
                                        <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colUsuarioId" prefWidth="140.0" text="Identificación" />
                                                <TableColumn fx:id="colUsuarioNombre" prefWidth="220.0" text="Nombre de Usuario" />
                                                <TableColumn fx:id="colUsuarioCorreo" prefWidth="230.0" text="Correo Electrónico" />
                                                <TableColumn fx:id="colUsuarioRol" prefWidth="130.0" text="Rol de Sistema" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="15.0" alignment="CENTER_RIGHT">
                                            <children>
                                                <Button onAction="#eliminarUsuario" text="❌ Eliminar Usuario" prefHeight="35.0" style="-fx-background-color: #ff4d4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="panelMetricas" spacing="25.0" visible="false">
                                    <children>
                                        <Label text="Métricas Generales del Sistema" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #001529;" />

                                        <GridPane hgap="20" vgap="20">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="25" />
                                                <ColumnConstraints percentWidth="25" />
                                                <ColumnConstraints percentWidth="25" />
                                                <ColumnConstraints percentWidth="25" />
                                            </columnConstraints>
                                            <children>
                                                <VBox fx:id="cardClientes" styleClass="card-metrica, card-clientes-claro" GridPane.columnIndex="0">
                                                    <children>
                                                        <Label text="TOTAL CLIENTES" styleClass="label-titulo-metrica" />
                                                        <Label fx:id="lblTotalClientes" text="0" styleClass="label-valor-metrica" />
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="cardEventos" styleClass="card-metrica, card-eventos-claro" GridPane.columnIndex="1">
                                                    <children>
                                                        <Label text="EVENTOS ACTIVOS" styleClass="label-titulo-metrica" />
                                                        <Label fx:id="lblTotalEventos" text="0" styleClass="label-valor-metrica" />
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="cardEntradas" styleClass="card-metrica, card-entradas-claro" GridPane.columnIndex="2">
                                                    <children>
                                                        <Label text="ENTRADAS VENDIDAS" styleClass="label-titulo-metrica" />
                                                        <Label fx:id="lblTotalEntradas" text="0" styleClass="label-valor-metrica" />
                                                    </children>
                                                </VBox>

                                                <VBox fx:id="cardIngresos" styleClass="card-metrica, card-ingresos-claro" GridPane.columnIndex="3">
                                                    <children>
                                                        <Label text="INGRESOS TOTALES" styleClass="label-titulo-metrica" />
                                                        <Label fx:id="lblTotalIngresos" text="\$ 0.00" styleClass="label-valor-metrica" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </GridPane>

                                        <VBox alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-border-color: #e8e8e8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                                            <children>
                                                <PieChart fx:id="chartIngresos" prefHeight="330" title="Distribución de Datos Operativos" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                            </children>
                        </StackPane>
                    </content>
                </ScrollPane>
            </children>
        </HBox>
    </children>
</AnchorPane>