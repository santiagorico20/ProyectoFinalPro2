<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" stylesheets="@styles.css" styleClass="pane-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinal.ViewController.DetalleCompraViewController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #161b22; -fx-padding: 0 30; -fx-border-color: #30363d; -fx-border-width: 0 0 1 0;" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#regresar" text="⬅️ Volver a Cartelera" styleClass="button-secondary" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblNombreEvento" text="Nombre del Evento" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #58a6ff;" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </top>

    <center>
        <HBox style="-fx-padding: 20;" spacing="20.0" BorderPane.alignment="CENTER">
            <children>

                <VBox spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="600.0">
                    <children>
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Selecciona tu Zona:" style="-fx-text-fill: white;" />
                                <ComboBox fx:id="comboZonas" prefWidth="250.0" promptText="Elige una localidad" />
                            </children>
                        </HBox>

                        <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 8; -fx-background-color: #0d1117; -fx-background-radius: 5;">
                            <children>
                                <Label text="🟩 Disponible" style="-fx-text-fill: #2ea043; -fx-font-weight: bold;" />
                                <Label text="🟨 Tu Selección (En Proceso)" style="-fx-text-fill: #d29922; -fx-font-weight: bold;" />
                                <Label text="🟥 Ocupado" style="-fx-text-fill: #f85149; -fx-font-weight: bold;" />
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <GridPane fx:id="gridAsientosCliente" alignment="CENTER" hgap="8.0" vgap="8.0" style="-fx-padding: 15;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox spacing="15.0" prefWidth="320.0" style="-fx-background-color: #161b22; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #30363d;">
                    <children>
                        <Label text="Resumen de Reserva" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #58a6ff;" />
                        <Separator />

                        <Label text="📍 Ubicación:" style="-fx-text-fill: #8b949e;" />
                        <Label fx:id="lblDetalleRecinto" text="Estadio / Teatro" style="-fx-text-fill: white; -fx-font-weight: bold;" />

                        <Label text="🪑 Asiento Seleccionado:" style="-fx-text-fill: #8b949e;" />
                        <Label fx:id="lblAsientoSeleccionado" text="Ninguno (Haz clic en el mapa)" style="-fx-text-fill: #ff79c6; -fx-font-weight: bold;" />

                        <Label text="💵 Valor a Pagar:" style="-fx-text-fill: #8b949e;" />
                        <Label fx:id="lblTotalPagar" text="\$ 0.00" style="-fx-text-fill: #50fa7b; -fx-font-size: 22px; -fx-font-weight: bold;" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button fx:id="btnProcederPago" disable="true" mnemonicParsing="false" onAction="#procesarPago" text="🔒 Confirmar y Pagar" prefWidth="300.0" style="-fx-background-color: #2ea043; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10;" />
                    </children>
                </VBox>

            </children>
        </HBox>
    </center>
</BorderPane>