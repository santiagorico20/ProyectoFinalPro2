<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" stylesheets="@styles.css" styleClass="pane-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinal.ViewController.MisComprasViewController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #161b22; -fx-padding: 0 30; -fx-border-color: #30363d; -fx-border-width: 0 0 1 0;" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#regresar" text="⬅️ Volver" styleClass="button-secondary" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Mis Entradas Digitales" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #58a6ff;" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-padding: 30;" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <VBox>
                    <children>
                        <Label text="Historial de Compras" styleClass="label-title" />
                        <Label text="Aquí encontrarás todos los tickets que has adquirido en Nexus Tickets." style="-fx-text-fill: #8b949e;" />
                    </children>
                </VBox>

                <TableView fx:id="tablaMisEntradas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTicket" text="Código Ticket" prefWidth="120.0" />
                        <TableColumn fx:id="colEvento" text="Evento" prefWidth="250.0" />
                        <TableColumn fx:id="colFecha" text="Fecha de Compra" prefWidth="180.0" />
                        <TableColumn fx:id="colAsiento" text="Asiento / Zona" prefWidth="200.0" />
                        <TableColumn fx:id="colPrecio" text="Valor Pagado" prefWidth="150.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>